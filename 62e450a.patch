diff --git a/public/css/theme.css b/public/css/theme.css
index 7a2e1c5..ecdaf08 100644
--- a/public/css/theme.css
+++ b/public/css/theme.css
@@ -492,6 +492,205 @@ body {
   letter-spacing: 1px;
 }
 
+/* ÔöÇÔöÇ Admin stat card (enhanced) ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ */
+.admin-stat {
+  background: var(--surface-card);
+  border: 1px solid var(--surface-card-border);
+  border-radius: var(--radius-lg);
+  padding: 1.25rem;
+  display: flex;
+  align-items: center;
+  gap: 1rem;
+  position: relative;
+  overflow: hidden;
+  transition: transform var(--transition-base), box-shadow var(--transition-base);
+}
+
+.admin-stat:hover {
+  transform: translateY(-2px);
+  box-shadow: 0 8px 24px rgba(0,0,0,0.2);
+}
+
+.admin-stat .stat-icon {
+  width: 48px;
+  height: 48px;
+  border-radius: var(--radius-md);
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  flex-shrink: 0;
+}
+
+.admin-stat .stat-icon.orange { background: rgba(255,140,66,0.12); color: var(--accent); }
+.admin-stat .stat-icon.blue   { background: rgba(59,130,246,0.12); color: #3b82f6; }
+.admin-stat .stat-icon.green  { background: rgba(34,197,94,0.12);  color: var(--success); }
+.admin-stat .stat-icon.purple { background: rgba(139,92,246,0.12); color: #8b5cf6; }
+
+.admin-stat .stat-info { flex: 1; min-width: 0; }
+
+.admin-stat .stat-info .stat-val {
+  font-size: 1.6rem;
+  font-weight: 800;
+  color: var(--text-primary);
+  line-height: 1.2;
+}
+
+.admin-stat .stat-info .stat-lbl {
+  color: var(--text-muted);
+  font-size: 0.78rem;
+  font-weight: 500;
+  letter-spacing: 0.5px;
+}
+
+/* ÔöÇÔöÇ Admin list item (enhanced) ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ */
+.admin-list-item {
+  display: flex;
+  align-items: center;
+  gap: 0.85rem;
+  padding: 0.85rem;
+  border-radius: var(--radius-md);
+  background: var(--surface-card);
+  border: 1px solid transparent;
+  transition: all var(--transition-base);
+}
+
+.admin-list-item:hover {
+  border-color: var(--surface-card-border);
+  background: var(--surface-elevated);
+}
+
+.admin-list-item .item-avatar {
+  width: 40px;
+  height: 40px;
+  border-radius: 50%;
+  background: var(--surface-elevated);
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  flex-shrink: 0;
+  color: var(--text-muted);
+  font-weight: 700;
+  font-size: 0.85rem;
+}
+
+.admin-list-item .item-body { flex: 1; min-width: 0; }
+.admin-list-item .item-body .item-name { font-weight: 600; font-size: 0.95rem; }
+.admin-list-item .item-body .item-sub { color: var(--text-muted); font-size: 0.8rem; }
+
+.admin-list-item .item-badge {
+  padding: 0.25rem 0.65rem;
+  border-radius: 20px;
+  font-size: 0.75rem;
+  font-weight: 600;
+  white-space: nowrap;
+}
+
+.admin-list-item .item-badge.balance {
+  background: rgba(34,197,94,0.1);
+  color: var(--success);
+}
+
+/* ÔöÇÔöÇ Admin section header ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ */
+.admin-section-header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  margin-bottom: 1rem;
+}
+
+.admin-section-header h3 {
+  font-size: 1rem;
+  font-weight: 700;
+  display: flex;
+  align-items: center;
+  gap: 0.5rem;
+}
+
+.admin-section-header h3 i { color: var(--accent); }
+
+/* ÔöÇÔöÇ Admin quick-link cards ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ */
+.admin-quick-links {
+  display: grid;
+  grid-template-columns: repeat(2, 1fr);
+  gap: 0.75rem;
+}
+
+.admin-quick-link {
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: 0.5rem;
+  padding: 1.25rem 0.75rem;
+  background: var(--surface-card);
+  border: 1px solid var(--surface-card-border);
+  border-radius: var(--radius-lg);
+  text-decoration: none;
+  color: var(--text-secondary);
+  font-size: 0.85rem;
+  font-weight: 500;
+  transition: all var(--transition-base);
+}
+
+.admin-quick-link:hover {
+  color: var(--text-primary);
+  border-color: var(--accent);
+  background: var(--surface-elevated);
+  transform: translateY(-2px);
+}
+
+.admin-quick-link i { color: var(--accent); }
+
+/* ÔöÇÔöÇ Admin form card ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ */
+.admin-form-group {
+  display: flex;
+  flex-direction: column;
+  gap: 0.6rem;
+}
+
+.admin-form-group label {
+  font-size: 0.8rem;
+  font-weight: 600;
+  color: var(--text-secondary);
+  letter-spacing: 0.3px;
+}
+
+.admin-form-group .input-row {
+  display: flex;
+  gap: 0.5rem;
+}
+
+/* ÔöÇÔöÇ Admin transaction row ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ */
+.admin-tx {
+  display: flex;
+  align-items: center;
+  gap: 0.75rem;
+  padding: 0.75rem 0;
+  border-bottom: 1px solid var(--surface-card-border);
+}
+
+.admin-tx:last-child { border-bottom: none; }
+
+.admin-tx .tx-icon {
+  width: 36px;
+  height: 36px;
+  border-radius: 50%;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  flex-shrink: 0;
+}
+
+.admin-tx .tx-icon.income  { background: rgba(34,197,94,0.1);  color: var(--success); }
+.admin-tx .tx-icon.expense { background: rgba(239,68,68,0.1);  color: var(--error); }
+
+.admin-tx .tx-info { flex: 1; min-width: 0; }
+.admin-tx .tx-info .tx-desc { font-weight: 500; font-size: 0.9rem; }
+.admin-tx .tx-info .tx-date { color: var(--text-muted); font-size: 0.78rem; }
+
+.admin-tx .tx-amount { font-weight: 700; font-size: 0.95rem; white-space: nowrap; }
+.admin-tx .tx-amount.pos { color: var(--success); }
+.admin-tx .tx-amount.neg { color: var(--error); }
+
 /* ÔöÇÔöÇ Toast ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ */
 .toast-container {
   position: fixed;
